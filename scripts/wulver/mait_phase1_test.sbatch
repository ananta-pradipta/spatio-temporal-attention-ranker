#!/bin/bash -l
#SBATCH --job-name=model-eval
#SBATCH --partition=gpu
#SBATCH --account=hz79
#SBATCH --qos=standard
#SBATCH --time=00:30:00
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=4
#SBATCH --gres=gpu:a100_20g:1
#SBATCH --mem=32G
#SBATCH --output=%x.%j.out
#SBATCH --error=%x.%j.err

set -euo pipefail
cd $HOME/phd-research
module load bright 2>/dev/null || true
module load python3 2>/dev/null || true
source $HOME/phd-research-gpu-env/bin/activate

echo "host=$(hostname) start=$(date -Is)"

# MAiT Phase 1 acceptance test. Login node kills the InvarDataset
# constructor on OOM; run inside a compute job with proper memory limit.
PYTHONPATH=$PWD python3 -m pytest tests/test_mait_data.py -v -s

echo "DONE $(date -Is)"
